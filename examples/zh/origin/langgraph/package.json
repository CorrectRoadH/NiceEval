{
  "name": "langgraph-otel-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,green \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": ".venv/bin/langgraph dev --port 2024 --no-browser",
    "dev:web": "wait-on -t 60000 tcp:127.0.0.1:2024 && vite",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/react": "^1.0.26",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "wait-on": "^9.0.0"
  }
}
