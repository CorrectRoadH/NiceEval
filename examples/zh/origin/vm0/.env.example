# 必填:vm0 平台的程序化调用 token。
# 获取方式:npm i -g @vm0/cli && vm0 auth login && vm0 auth setup-token
# (setup-token 是官方给 CI/程序化调用发 token 的通道;ZERO_TOKEN 优先级更高,
# 和官方 CLI 的取值顺序一致。)
VM0_TOKEN=

# 沙箱里 claude-code 的模型凭证,按 vm0 的机制走 run secrets 注入
# (`vm0 init` 的官方示例就是 --secrets CLAUDE_CODE_OAUTH_TOKEN=...)。
# 平台只存 secret 名字不存值,所以本 server 每轮都会重传。二选一:
CLAUDE_CODE_OAUTH_TOKEN=
#ANTHROPIC_API_KEY=
# 配 ANTHROPIC_API_KEY 走 Anthropic 兼容端点时可以再带上:
#ANTHROPIC_BASE_URL=

# 可选:API 地址,默认 https://www.vm0.ai(和官方 CLI 相同)。
#VM0_API_URL=https://www.vm0.ai

# 可选:agent compose 的名字,默认 niceeval-demo(和本目录 vm0.yaml 一致)。
# 改了 vm0.yaml 里的名字要同步改这里。
#VM0_AGENT_NAME=niceeval-demo

# 可选:server.ts 监听端口,默认 5588。
#PORT=5588
