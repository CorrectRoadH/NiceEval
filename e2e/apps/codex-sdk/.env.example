# e2e 用的最小变量集(CI 由 workflow 从 secrets 写入同样内容,见 .github/workflows/e2e.yml)。
CODEX_API_KEY=sk-replace-me
CODEX_BASE_URL=https://your-proxy.example.com/v1
AGENT_MODEL=gpt-5.4
# CI/容器里 Codex CLI 的 bwrap 沙箱起不来,设 danger-full-access 关内层沙箱
# (runner 本身即一次性隔离环境);本地不设,保持 Codex 默认沙箱。
#CODEX_SANDBOX_MODE=danger-full-access
